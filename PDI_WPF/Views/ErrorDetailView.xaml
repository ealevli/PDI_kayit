<UserControl x:Class="PDI_WPF.Views.ErrorDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" /> <!-- Grafik Alanı Daha Büyük -->
            <RowDefinition Height="Auto" />  <!-- Tablo Alanı (Auto = İçerik kadar) -->
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold"
            HorizontalAlignment="Center" Margin="0,0,0,20" />

        <!-- Grafik -->
        <lvc:CartesianChart Grid.Row="1" Series="{Binding DetailSeries}" XAxes="{Binding XAxes}"
            LegendPosition="Bottom" />

        <!-- Detay Tablo -->
        <Border Grid.Row="2" CornerRadius="5" BorderBrush="#DDD" BorderThickness="1"
            Margin="0,20,0,0">
            <DataGrid ItemsSource="{Binding GridData}" AutoGenerateColumns="False" IsReadOnly="True"
                HeadersVisibility="Column" GridLinesVisibility="All"
                AlternatingRowBackground="#F9F9F9">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#444" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Padding" Value="5" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Son 12 Ay" Binding="{Binding RowHeader}" Width="150"
                        FontWeight="Bold" />
                    <DataGridTextColumn Header="ŞUB" Binding="{Binding Sub}" Width="*" />
                    <DataGridTextColumn Header="MAR" Binding="{Binding Mar}" Width="*" />
                    <DataGridTextColumn Header="NİS" Binding="{Binding Nis}" Width="*" />
                    <DataGridTextColumn Header="MAY" Binding="{Binding May}" Width="*" />
                    <DataGridTextColumn Header="HAZ" Binding="{Binding Haz}" Width="*" />
                    <DataGridTextColumn Header="TEM" Binding="{Binding Tem}" Width="*" />
                    <DataGridTextColumn Header="AĞU" Binding="{Binding Agu}" Width="*" />
                    <DataGridTextColumn Header="EYL" Binding="{Binding Eyl}" Width="*" />
                    <DataGridTextColumn Header="EKİ" Binding="{Binding Eki}" Width="*" />
                    <DataGridTextColumn Header="KAS" Binding="{Binding Kas}" Width="*" />
                    <DataGridTextColumn Header="ARA" Binding="{Binding Ara}" Width="*" />
                    <DataGridTextColumn Header="OCA" Binding="{Binding Oca}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>