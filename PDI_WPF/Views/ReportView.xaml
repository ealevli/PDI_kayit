<UserControl x:Class="PDI_WPF.Views.ReportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Background="White" Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sol Taraf: Ana Grafik ve Özet -->
        <Grid Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Alanı: Başlık ve Filtreler -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold"
                    VerticalAlignment="Center" />

                <!-- Sağ Üst: Ay/Yıl Seçimi ve Edit Butonu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ay:" VerticalAlignment="Center" Margin="0,0,5,0"
                        Foreground="#666" />
                    <ComboBox ItemsSource="{Binding MonthList}"
                        SelectedIndex="{Binding SelectedMonth, Converter={StaticResource MonthIndexConverter}, Mode=TwoWay}"
                        Width="100" Padding="5" Margin="0,0,10,0" />

                    <TextBlock Text="Yıl:" VerticalAlignment="Center" Margin="0,0,5,0"
                        Foreground="#666" />
                    <ComboBox ItemsSource="{Binding YearList}"
                        SelectedItem="{Binding SelectedYear}"
                        Width="80" Padding="5" Margin="0,0,10,0" />

                    <Button Content="📝 Verileri Düzenle"
                        Command="{Binding EditDataCommand}"
                        Padding="10,5" Background="#eee"
                        BorderBrush="#ccc" BorderThickness="1" Cursor="Hand" />
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="1" Text="{Binding ReportMonthInfo}" TextWrapping="Wrap"
                Margin="0,0,0,20" FontSize="14" Foreground="#555" />

            <!-- Ana Combo Chart -->
            <lvc:CartesianChart Grid.Row="2" Series="{Binding MainChartSeries}"
                XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" LegendPosition="Right" />
        </Grid>

        <!-- Sağ Taraf: Dairesel Göstergeler -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Gauge 1: Geçen Yıl -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding Gauge1Title}" HorizontalAlignment="Center"
                            FontWeight="Bold" Margin="0,5" />
                        <lvc:PieChart Series="{Binding Gauge1Series}" Height="150"
                            InitialRotation="-90" />
                        <TextBlock Text="{Binding Gauge1Value}" FontSize="24" FontWeight="Bold"
                            HorizontalAlignment="Center" Margin="0,-80,0,40" Foreground="#333" />
                        <TextBlock Text="{Binding Gauge1Text}" HorizontalAlignment="Center"
                            Foreground="#777" FontSize="12" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Gauge 2: Son 12 Ay -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding Gauge2Title}" HorizontalAlignment="Center"
                            FontWeight="Bold" Margin="0,5" />
                        <lvc:PieChart Series="{Binding Gauge2Series}" Height="150"
                            InitialRotation="-90" />
                        <TextBlock Text="{Binding Gauge2Value}" FontSize="24" FontWeight="Bold"
                            HorizontalAlignment="Center" Margin="0,-80,0,40" Foreground="#333" />
                        <TextBlock Text="{Binding Gauge2Text}" HorizontalAlignment="Center"
                            Foreground="#777" FontSize="12" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- Gauge 3: Mevcut Yıl -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Gauge3Title}" HorizontalAlignment="Center"
                            FontWeight="Bold" Margin="0,5" />
                        <lvc:PieChart Series="{Binding Gauge3Series}" Height="150"
                            InitialRotation="-90" />
                        <TextBlock Text="{Binding Gauge3Value}" FontSize="24" FontWeight="Bold"
                            HorizontalAlignment="Center" Margin="0,-80,0,40" Foreground="#333" />
                        <TextBlock Text="{Binding Gauge3Text}" HorizontalAlignment="Center"
                            Foreground="#777" FontSize="12" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>