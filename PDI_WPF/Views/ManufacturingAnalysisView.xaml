<UserControl x:Class="PDI_WPF.Views.ManufacturingAnalysisView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Başlık ve Filtre -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding FilterInfo}" Foreground="#666" FontSize="14"
                    Margin="0,5,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="Yıl:" VerticalAlignment="Center" Margin="0,0,10,0" />
                <ComboBox ItemsSource="{Binding YearList}"
                    SelectedItem="{Binding SelectedYear}"
                    Width="100"
                    Padding="5" />
                <Button Content="🔄 Yenile"
                    Command="{Binding RefreshCommand}"
                    Background="#f8f9fa"
                    Padding="10,5"
                    Margin="10,0,0,0"
                    Cursor="Hand" />
            </StackPanel>
        </Grid>

        <!-- Özet Kartları -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Background="#e3f2fd">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Geçen Yıl İmalat" Foreground="#666" FontSize="12" />
                    <TextBlock Text="{Binding PrevYearTotal}" FontSize="28" FontWeight="Bold"
                        HorizontalAlignment="Center" />
                    <TextBlock Text="araç" Foreground="#666" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,0"
                Background="#e8f5e9">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Bu Yıl İmalat" Foreground="#666" FontSize="12" />
                    <TextBlock Text="{Binding CurrYearTotal}" FontSize="28" FontWeight="Bold"
                        Foreground="#28a745" HorizontalAlignment="Center" />
                    <TextBlock Text="araç" Foreground="#666" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="5,0"
                Background="#fff3e0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Geçen Yıl Ort." Foreground="#666" FontSize="12" />
                    <TextBlock Text="{Binding PrevYearRate}" FontSize="28" FontWeight="Bold"
                        Foreground="#f57c00" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="10,0,0,0"
                Background="#fce4ec">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Bu Yıl Ort." Foreground="#666" FontSize="12" />
                    <TextBlock Text="{Binding CurrYearRate}" FontSize="28" FontWeight="Bold"
                        Foreground="#c2185b" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Ana Grafik -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="📈 İmalata Gidiş Trend Grafiği (Yıllık Karşılaştırma)"
                        FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />

                    <lvc:CartesianChart Grid.Row="1"
                        Series="{Binding TrendSeries}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"
                        LegendPosition="Top" />
                </Grid>
            </Border>

            <!-- Sağ: Top Hatalar -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="🏷️ İmalata Giden Top Hatalar" FontWeight="Bold" FontSize="14"
                        Margin="0,0,0,10" />

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TopErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#f8f9fa" Margin="0,0,0,5" Padding="10"
                                    CornerRadius="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding HataAdi}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="1"
                                            Text="{Binding Adet, StringFormat='{}{0} adet'}"
                                            Foreground="#666" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Alt: İşlem Butonları -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,15,0,0">
            <Button Content="📝 Verileri Düzenle"
                Command="{Binding EditDataCommand}"
                Background="#6c757d"
                Foreground="White"
                Padding="15,10"
                Cursor="Hand" />
        </StackPanel>
    </Grid>
</UserControl>