<UserControl x:Class="PDI_WPF.Views.NewRecordView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="20">
        <!-- Tam genişlik için Border'ın hizalamasını Stretch yapıyoruz -->
        <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top"
            HorizontalAlignment="Stretch">
            <StackPanel Margin="10">
                <TextBlock Text="YENİ PDI KAYDI OLUŞTUR" FontSize="20" FontWeight="Bold"
                    Margin="0,0,0,20" Foreground="#333" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" /><!-- Spacer -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="5">
                        <TextBlock Text="BB No" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Text="{Binding BbNo}" Padding="8" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Şasi No" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Text="{Binding SasiNo}" Padding="8" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="5">
                        <TextBlock Text="Araç Tipi" FontWeight="Bold" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding AracTipleri}"
                            SelectedItem="{Binding SelectedAracTipi}" Padding="8" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="5">
                        <TextBlock Text="Alt Grup" FontWeight="Bold" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding AltGruplar}"
                            SelectedItem="{Binding SelectedAltGrup}" Padding="8" />
                    </StackPanel>

                    <!-- Tespitler Alanı daha geniş ve yüksek -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="5">
                        <TextBlock Text="Tespitler" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Text="{Binding Tespitler}" Padding="8" Height="120"
                            TextWrapping="Wrap" AcceptsReturn="True"
                            VerticalScrollBarVisibility="Auto" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="5">
                        <TextBlock Text="Hata Konumu" FontWeight="Bold" Margin="0,0,0,5" />
                        <TextBox Text="{Binding HataKonumu}" Padding="8" />
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="5">
                        <TextBlock Text="Top Hata Tanımı" FontWeight="Bold" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding TopHatalar}"
                            SelectedItem="{Binding SelectedTopHata}" Padding="8" />
                    </StackPanel>

                    <Button Grid.Row="4" Grid.ColumnSpan="3" Content="KAYDET"
                        Command="{Binding SaveCommand}"
                        Background="#28a745" Foreground="White" FontWeight="Bold" Padding="15"
                        Margin="5,30,5,5" BorderThickness="0" Cursor="Hand" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>