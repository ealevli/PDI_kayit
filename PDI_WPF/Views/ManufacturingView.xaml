<UserControl x:Class="PDI_WPF.Views.ManufacturingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="İMALAT TAKİP LİSTESİ" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

        <!-- Filtreler ve Kontroller -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBox Width="200"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Tag="Araç No Ara..." Padding="5" />
                    <Button Content="YENİLE" Command="{Binding RefreshCommand}" Margin="10,0"
                        Width="80" />
                </StackPanel>
                <Button Content="+ İMALATA GÖNDER" HorizontalAlignment="Right" Background="#007bff"
                    Foreground="White" Width="150" FontWeight="Bold" />
            </Grid>
        </Border>

        <!-- İmalat Tablosu -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True"
                Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                    <DataGridTextColumn Header="Araç No" Binding="{Binding AracNo}" Width="150" />
                    <DataGridTextColumn Header="Tarih" Binding="{Binding Tarih}" Width="150" />
                    <DataGridTextColumn Header="Top Hata" Binding="{Binding TopHata}" Width="*" />
                    <DataGridTemplateColumn Header="Durum" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Color}" CornerRadius="3" Padding="5,2">
                                    <TextBlock Text="{Binding Durum}" Foreground="White"
                                        FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="İşlemler" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Tamamla" Background="Transparent"
                                    BorderThickness="0" Foreground="Green" FontWeight="Bold" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>