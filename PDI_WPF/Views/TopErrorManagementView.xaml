<UserControl x:Class="PDI_WPF.Views.TopErrorManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Text="TOP HATA YÖNETİMİ" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

        <!-- İki Sütunlu Düzen -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- Sol: Top Hata Listesi -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Aktif Top Hatalar" FontWeight="Bold" FontSize="14"
                        Margin="0,0,0,10" />

                    <ListBox Grid.Row="1"
                        ItemsSource="{Binding TopHatalar}"
                        SelectedItem="{Binding SelectedHata}"
                        FontSize="14"
                        Padding="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="🏷️" Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2"
                        Content="🗑️ SEÇİLİ HATAYI SİL"
                        Command="{Binding DeleteHataCommand}"
                        Background="#dc3545"
                        Foreground="White"
                        Padding="15,10"
                        Margin="0,15,0,0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        HorizontalAlignment="Left" />
                </Grid>
            </Border>

            <!-- Sağ: Yeni Hata Ekleme -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Yeni Top Hata Ekle" FontWeight="Bold" FontSize="14"
                        Margin="0,0,0,15" />

                    <TextBlock
                        Text="Bu liste, kayıt girerken 'Top Hata' dropdown'ında görünecek standart hata isimlerini tanımlar."
                        TextWrapping="Wrap"
                        Foreground="#666"
                        FontSize="12"
                        Margin="0,0,0,20" />

                    <TextBlock Text="Hata Adı:" Margin="0,0,0,5" />
                    <TextBox Text="{Binding NewHataAdi, UpdateSourceTrigger=PropertyChanged}"
                        FontSize="14"
                        Padding="8"
                        Margin="0,0,0,15" />

                    <Button Content="➕ HATA EKLE"
                        Command="{Binding AddHataCommand}"
                        Background="#28a745"
                        Foreground="White"
                        Padding="15,10"
                        FontWeight="Bold"
                        Cursor="Hand" />

                    <Separator Margin="0,25" />

                    <TextBlock Text="💡 İpucu" FontWeight="Bold" Margin="0,0,0,5" />
                    <TextBlock
                        Text="Hata silme işlemi geri alınamaz. Silinen hatalar raporlarda gösterilmez ancak veritabanında kayıtlı kalmaya devam eder."
                        TextWrapping="Wrap"
                        Foreground="#666"
                        FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>