<UserControl x:Class="PDI_WPF.Views.DataUploadView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Text="GEÇMİŞ VERİ YÜKLE (EXCEL)" FontSize="24" FontWeight="Bold"
            Margin="0,0,0,20" />

        <!-- Bilgi Kutusu -->
        <Border Grid.Row="1" Background="#f8f9fa" BorderBrush="#dee2e6" BorderThickness="1"
            Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Excel dosyanız aşağıdaki sütunları içermelidir (Otomatik tanınır):"
                    FontWeight="Bold" Margin="0,0,0,10" />
                <TextBlock
                    Text="BB No | Şasi No | Araç Tipi | İş Emri No | PDI Tarihi | Tespitler | Hata Konumu | Alt Grup"
                    FontFamily="Consolas" Background="White" Padding="10" Margin="0,0,0,15" />

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="⚠️" Margin="0,0,5,0" />
                    <TextBlock Text="'Kullanıcı' sütunu gerekmez (otomatik atanır)." />
                </StackPanel>

                <TextBlock Text="⚠️ Araç Tipi Kısaltmaları Desteklenir:" FontWeight="SemiBold"
                    Margin="0,10,0,5" />
                <TextBlock Text="   • TOU → Tourismo" Foreground="#666" />
                <TextBlock Text="   • TRV → Travego" Foreground="#666" />
                <TextBlock Text="   • CON → Connecto" Foreground="#666" />
            </StackPanel>
        </Border>

        <!-- Dosya Seçici -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Excel Dosyası:" VerticalAlignment="Center" FontWeight="Bold"
                    Margin="0,0,15,0" />

                <TextBox Grid.Column="1"
                    Text="{Binding FilePath, Mode=OneWay}"
                    IsReadOnly="True"
                    FontSize="13"
                    Padding="8"
                    VerticalAlignment="Center" />

                <Button Grid.Column="2"
                    Content="📁 GÖZAT"
                    Command="{Binding BrowseCommand}"
                    Background="#6c757d"
                    Foreground="White"
                    Padding="15,8"
                    Margin="10,0"
                    Cursor="Hand" />

                <Button Grid.Column="3"
                    Content="📥 İÇERİ AKTAR"
                    Command="{Binding ImportCommand}"
                    Background="#28a745"
                    Foreground="White"
                    Padding="20,8"
                    FontWeight="Bold"
                    Cursor="Hand"
                    IsEnabled="{Binding IsImporting, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>
        </Border>

        <!-- Sonuç Alanı -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="📋 Sonuç" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox Text="{Binding ResultText, Mode=OneWay}"
                        IsReadOnly="True"
                        FontFamily="Consolas"
                        FontSize="12"
                        Background="#f9f9f9"
                        BorderThickness="0"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>