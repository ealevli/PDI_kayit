<UserControl x:Class="PDI_WPF.Views.UserManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <TextBlock Text="KULLANICI YÖNETİMİ" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- İki Sütunlu Düzen -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sol: Kullanıcı Listesi -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Mevcut Kullanıcılar" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Users}" 
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Kullanıcı Adı" Binding="{Binding Username}" Width="*"/>
                            <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="80"/>
                            <DataGridTextColumn Header="Açıklama" Binding="{Binding Aciklama}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Sağ: Yeni Kullanıcı Formu -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Yeni Kullanıcı Ekle" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                    <TextBlock Text="Kullanıcı Adı:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Text="Şifre:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                    <TextBlock Text="Rol:" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding RoleList}" SelectedItem="{Binding NewRole}" Margin="0,0,0,10"/>

                    <TextBlock Text="Açıklama:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding NewAciklama, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                    <Button Content="➕ KULLANICI EKLE" 
                            Command="{Binding AddUserCommand}" 
                            Background="#28a745" 
                            Foreground="White" 
                            Padding="10,8" 
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Alt: İşlem Butonları -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">
            <Button Content="🗑️ SEÇİLİ KULLANICIYI SİL" 
                    Command="{Binding DeleteUserCommand}" 
                    Background="#dc3545" 
                    Foreground="White" 
                    Padding="15,10" 
                    Margin="0,0,10,0"
                    FontWeight="Bold"
                    Cursor="Hand"/>
            <Button Content="🔄 YENİLE" 
                    Command="{Binding RefreshCommand}" 
                    Background="#6c757d" 
                    Foreground="White" 
                    Padding="15,10"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>
