    def show_dashboard(self):
        self.clear_content()
        # Header
        h = tk.Frame(self.content_area, bg=COLOR_BG); h.pack(fill="x", padx=30, pady=30)
        tk.Label(h, text="GENEL ÖZET", font=FONT_HEADER, bg=COLOR_BG).pack(side="left")
        
        # Filter
        self.dash_filter = tk.StringVar(value="TÜMÜ")
        months = ["TÜMÜ"] + [f"{TURKISH_MONTHS[i]} 2024" for i in range(1,13)]
        ttk.Combobox(h, textvariable=self.dash_filter, values=months).pack(side="right")
        tk.Button(h, text="YENİLE", command=self.show_dashboard).pack(side="right", padx=5)
        def calc():
            if self.df is None or self.df.empty: return [0]*5
            d = self.df.copy()
            if self.dash_filter.get() != "TÜMÜ":
                try:
                    mn = self.dash_filter.get().split()[0]
                    mi = next((k for k,v in TURKISH_MONTHS.items() if v==mn), 0)
                    d = d[d['month'] == mi]
                except: pass
            
            return [
                d['sasi_no'].nunique(),
                len(d),
                d[d['arac_tipi']=='Tourismo']['sasi_no'].nunique(),
                d[d['arac_tipi']=='Travego']['sasi_no'].nunique(),
                d[d['arac_tipi']=='Connecto']['sasi_no'].nunique()
            ]
        def draw(res):
            f = tk.Frame(self.content_area, bg=COLOR_BG); f.pack(fill="x", padx=30)
            self.card(f, "ARAÇ", res[0], 0, "#fff")
            self.card(f, "HATA", res[1], 1, "#fff")
            self.card(f, "TOURISMO", res[2], 2, "#eef")
            self.card(f, "TRAVEGO", res[3], 3, "#eef")
            self.card(f, "CONNECTO", res[4], 4, "#efe")
        self.run_in_background(calc, draw)
    def card(self, p, t, v, c, bg):
        fr = tk.Frame(p, bg=bg, padx=20, pady=20); fr.grid(row=0, column=c, sticky="ew", padx=10)
        tk.Label(fr, text=t, bg=bg, fg="#888").pack(anchor="w")
        tk.Label(fr, text=str(v), bg=bg, font=FONT_CARD_NUM).pack(anchor="w")
