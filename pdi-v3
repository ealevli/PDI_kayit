    # --- CORE VERİ YÖNETİMİ ---
    
    def start_async_data_load(self, callback=None):
        if self.is_data_loading: return
        self.is_data_loading = True
        
        def worker():
            try:
                conn = sqlite3.connect(DB_NAME)
                # Tabloları çek
                df = pd.read_sql("SELECT * FROM pdi_kayitlari", conn)
                top_h = pd.read_sql("SELECT hata_adi FROM top_hatalar WHERE aktif=1", conn)
                conn.close()
                
                # Tarih İşleme
                df['tarih_saat'] = df['tarih_saat'].astype(str).str.strip().str.replace('/', '-').str.replace('.', '-')
                df['dt_obj'] = pd.to_datetime(df['tarih_saat'], format='%d-%m-%Y', errors='coerce')
                
                mask_nat = df['dt_obj'].isna()
                if mask_nat.any():
                    # Fallback parse
                    df.loc[mask_nat, 'dt_obj'] = pd.to_datetime(df.loc[mask_nat, 'tarih_saat'], errors='coerce')
                
                df['year'] = df['dt_obj'].dt.year
                df['month'] = df['dt_obj'].dt.month
                # Sıralama için
                df.sort_values(by='dt_obj', ascending=False, inplace=True)
                
                self.df = df
                self.top_hatalar_cache = top_h['hata_adi'].tolist()
                
            except Exception as e:
                print(f"Data Load Error: {e}")
            finally:
                self.is_data_loading = False
                if callback: self.root.after(0, callback)
        thread = threading.Thread(target=worker, daemon=True)
        thread.start()
    def refresh_data(self, callback=None):
        self.start_async_data_load(callback)
    def run_in_background(self, task_func, on_complete):
        loading_win = tk.Toplevel(self.root)
        loading_win.title("İşlem")
        loading_win.geometry("300x120")
        loading_win.resizable(False, False)
        x = self.root.winfo_x() + (self.root.winfo_width() // 2) - 150
        y = self.root.winfo_y() + (self.root.winfo_height() // 2) - 60
        loading_win.geometry(f"+{x}+{y}")
        loading_win.transient(self.root)
        loading_win.grab_set()
        
        tk.Label(loading_win, text="İşleniyor...", font=("Segoe UI", 12)).pack(pady=20)
        pb = ttk.Progressbar(loading_win, mode='indeterminate')
        pb.pack(fill="x", padx=20)
        pb.start(10)
        def worker():
            res = None
            err = None
            try:
                # Veri bekle
                waits = 0
                while self.is_data_loading and waits < 50:
                    time.sleep(0.1); waits+=1
                
                if self.df is None: # Hala yoksa sync yükle
                    conn = sqlite3.connect(DB_NAME)
                    self.df = pd.read_sql("SELECT * FROM pdi_kayitlari", conn)
                    conn.close()
                    # (Tarih parsing burda pas geçiliyor speed için, gerekirse eklenir)
                res = task_func()
            except Exception as e: err = e
            
            self.root.after(0, lambda: [loading_win.destroy(), messagebox.showerror("Hata", str(err)) if err else on_complete(res)])
        threading.Thread(target=worker, daemon=True).start()
