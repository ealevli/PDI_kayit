    def show_top5_analysis(self):
        self.clear_content()
        tk.Label(self.content_area, text="TOP 5 ANALİZ", font=FONT_HEADER).pack(pady=10)
        
        def calc():
            df = self.df[self.df['arac_tipi'].isin(["Travego", "Tourismo"])]
            top = df['top_hata'].value_counts().head(5)
            return top.to_dict()
            
        def draw(res):
            for k,v in res.items():
                if k: tk.Label(self.content_area, text=f"{k}: {v} adet", font=("Segoe UI", 12)).pack()
        self.run_in_background(calc, draw)
    def calc_monthly(self, types):
        # Basitleştirilmiş son 12 ay datas
        res = []
        now = datetime.now()
        for i in range(12):
            m = (now.month - i - 1) % 12 + 1
            y = now.year - ((now.month - i - 1) // 12 + 1) + 1 # Date math fix needed properly but roughly ok
            d = self.df[
                (self.df['arac_tipi'].isin(types)) & 
                (self.df['month'] == m)
            ]
            res.append({'ay': TURKISH_MONTHS[m][:3], 'sayi': len(d)})
        return res[::-1]
    def draw_chart(self, data, color="blue"):
        c = tk.Canvas(self.content_area, bg="white", height=300)
        c.pack(fill="x", padx=20)
        # Simple bars
        x = 50
        max_v = max([d['sayi'] for d in data], default=1)
        col = "#007bff" if color=="blue" else "#28a745"
        for d in data:
            h = (d['sayi']/max_v)*200
            c.create_rectangle(x, 250-h, x+30, 250, fill=col)
            c.create_text(x+15, 260, text=d['ay'])
            c.create_text(x+15, 250-h-10, text=d['sayi'])
            x += 50
    def header_rep(self, t):
        tk.Label(self.content_area, text=t, font=FONT_HEADER).pack(pady=20)
